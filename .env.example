# Copy to .env and fill in your keys. Do not commit .env.

OPENAI_API_KEY=
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_API_URL=https://platform.unstructuredapp.io

# Qdrant Cloud (optional; omit for local qdrant_db)
QDRANT_URL=
QDRANT_API_KEY=

# OpenAI usage log file (optional; default: data/usage.json). On Render, set to a path on a persistent disk to keep totals across deploys.
# USAGE_FILE=/path/to/usage.json
